# ==============================================================================
# Public build-time configuration. These values are baked into the client
# bundle and are visible to every visitor — they must NEVER contain secrets.
# Copy this file to `.env` and fill in your own values for local development.
# ==============================================================================

# MapTiler Cloud API key for the three basemaps (free account: https://cloud.maptiler.com/).
# Restrict the key to your own origins in the MapTiler dashboard.
PUBLIC_MAPTILER_KEY=YOUR_MAPTILER_KEY

# BRouter routing endpoint. Development default is the public community server;
# production should point at our self-hosted instance.
PUBLIC_BROUTER_URL=https://brouter.de/brouter

# Terrarium-encoded elevation tiles ({z}/{x}/{y} template). Default is the
# keyless AWS Open Data Terrain Tiles dataset.
PUBLIC_ELEVATION_TILE_URL=https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png
